PORT=5000
JWT_SECRET=caveo_travel_super_secret_jwt_key_2024
JWT_EXPIRES_IN=7d

# ⚠️ CRITICAL — PostgreSQL (production)
# If USE_DATABASE=false, all data will be LOST on every deploy!
# Render/Railway/Heroku have ephemeral filesystems.
# You MUST use PostgreSQL in production.
USE_DATABASE=false
DATABASE_URL=postgresql://user:password@localhost:5432/caveo_travel

# Or individual fields
DB_HOST=localhost
DB_PORT=5432
DB_NAME=caveo_travel
DB_USER=postgres
DB_PASSWORD=password

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Admin credentials (for seeding)
ADMIN_EMAIL=admin@caveotravel.com
ADMIN_PASSWORD=Admin@2024

FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
