{
  "name": "caveo-travel-backend",
  "version": "3.0.0",
  "description": "CAVÉO TRAVEL — Backend API (Persistent JSON Storage)",
  "main": "src/server.js",
  "scripts": {
    "dev":    "nodemon src/server.js",
    "start":  "node src/server.js",
    "backup": "node -e \"const fs=require('fs');const d=require('./data/caveo-data.json');fs.writeFileSync('./data/backup-'+Date.now()+'.json',JSON.stringify(d,null,2));console.log('Backup yaradıldı');\""
  },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "cors":              "^2.8.5",
    "dotenv":            "^16.3.1",
    "express":           "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "multer":            "^1.4.5-lts.1",
    "nodemailer":        "^6.9.8",
    "pg":                "^8.11.3",
    "uuid":              "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
